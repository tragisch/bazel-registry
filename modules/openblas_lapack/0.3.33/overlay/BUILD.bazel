load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_cc//cc:cc_test.bzl", "cc_test")

package(default_visibility = ["//visibility:public"])

cc_library(
    name = "openblas_lapack",
    deps = ["@openblas//:openblas"],
)

cc_test(
    name = "openblas_lapack_smoke_test",
    srcs = ["//bazel:openblas_lapack_smoke_test.c"],
    deps = [":openblas_lapack"],
)

test_suite(
    name = "openblas_lapack_tests",
    tests = [
        ":openblas_lapack_smoke_test",
    ],
)
